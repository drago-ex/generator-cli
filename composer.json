{
	"name": "drago-ex/generator-cli",
	"type": "project",
	"description": "Basic configuration for Drago Generator",
	"authors": [
		{
			"name": "Zdeněk Papučík",
			"homepage": "https://github.com/accgit"
		}
	],
	"require": {
		"php": ">=8.3 <9",
		"drago-ex/bootstrap": "^2.0",
		"drago-ex/generator": "^1.1",
		"drago-ex/project-docker": "^2.0",
		"drago-ex/project-docker-db": "^2.0",
		"tracy/tracy": "^2.10"
	},
	"require-dev": {
		"phpstan/phpstan-nette": "^2.0",
		"drago-ex/project-tools": "^1.0"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app"
		}
	},
	"extra": {
		"drago-tools": {
			"vendor-names": ["drago-ex"],
			"allow-library-install": true
		}
	},
	"scripts": {
		"phpstan": "phpstan analyse",
		"post-install-cmd": [
			"drago-install",
			"drago-clean"
		],
		"post-update-cmd": [
			"drago-install",
			"drago-clean"
		],
		"generate:entity": "vendor/bin/generator app:entity",
		"generate:data-class": "vendor/bin/generator app:dataClass"
	}
}
